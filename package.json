{
  "name": "@onsvisual/sveltekit-starter",
  "homepage": "http://onsdigital.github.io/sveltekit-starter",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node ./scripts/js-fix",
    "build:preview": "cross-env PUBLIC_APP_ENV=preview vite build",
    "package": "vite package",
    "preview": "vite preview",
    "deploy": "gh-pages -d build -t true",
    "lint": "prettier --ignore-path .gitignore --check --plugin-search-dir=. .",
    "format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. ."
  },
  "author": "Ahmad Barclay",
  "license": "MIT",
  "devDependencies": {
    "@onsvisual/svelte-charts": "^0.4.11",
    "@onsvisual/svelte-components": "^1.0.21",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.5.27",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.1.1",
    "prettier": "^3.1.0",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "vite": "^5.4.4"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "sirv-cli": "^1.0.0"
  },
  "type": "module"
}
